{
  "name": "opencode-tasks",
  "version": "0.2.0",
  "description": "Scheduled task runner plugin for OpenCode - cron-based recurring and one-off task scheduling",
  "type": "module",
  "main": "./dist/plugin.js",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "bin": {
    "opencode-tasks": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "skill"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "opencode",
    "scheduler",
    "cron",
    "tasks",
    "automation",
    "plugin"
  ],
  "author": "Jeremy Dormitzer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdormit/opencode-tasks.git"
  },
  "dependencies": {
    "cron-parser": "^5.0.0",
    "gray-matter": "^4.0.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.15.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@opencode-ai/sdk": "^1.0.0",
    "@types/bun": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  }
}
